        ".ytcp-button[aria-label=\"Close\"]"
      ],
      "dialog_js": "var dlg = document.querySelector('ytcp-uploads-dialog'); if (dlg) { var cb = dlg.querySelector('#close-button'); if (cb) cb.click(); }"
    },
    "confirm": {
      "success_signals": [
        "text:Video published",
        "text:视频已发布",
        "text:已发布",
        "text:Published",
        "text:Processing will begin shortly",
        "text:即将开始处理",
        "text:Video upload complete",
        "text:视频上传完成",
        "text:Upload complete",
        "text:上传完成",
        "text:已安排好视频发布时间",
        "text:Video scheduled",
        "text:Scheduled",
        "text:已排定",
        "text:已排定时间",
        "text:已定时发布",
        "text:已安排发布",
        "text:计划于",
        "text:Scheduled for",
        "text:Set to publish",
        "text:Will be published"
      ],
      "success_url_pattern": {
