    "schedule": {
      "expand_button": "#second-container-expand-button",
      "scheduler_selector": "ytcp-visibility-scheduler",
      "date_dropdown": "ytcp-dropdown-trigger",
      "time_input_type": "input[type=\"text\"]",
      "time_container": "#second-container",
      "public_radio": "tp-yt-paper-radio-button[name=\"PUBLIC\"]"
    },
    "schedule_recipe": {
      "version": 3,
      "steps": [
        {
          "id": "select_public",
          "action": "click",
          "target": {
            "selector": "tp-yt-paper-radio-button[name=\"PUBLIC\"]",
            "fallbacks": []
          },
          "fallback": {
            "text_match": [
              "Public",
              "公开"
            ]
          },
          "wait_after_ms": 1500,
          "semantic_hint": "PUBLIC 公开 visibility radio button"
        },
        {
          "id": "expand_schedule",
          "action": "click",
          "target": {
            "selector": "#second-container-expand-button",
            "fallbacks": []
          },
          "fallback": {
            "text_match": [
              "Schedule",
              "安排时间",
              "定时发布"
            ]
          },
          "wait_after_ms": 1500,
          "semantic_hint": "schedule 安排时间 展开 expand button"
        },
        {
          "id": "wait_scheduler",
          "action": "wait",
          "target": {
            "selector": "ytcp-visibility-scheduler",
            "fallbacks": [
              "#publish-from-private-non-sponsor-selector"
            ]
          },
          "max_wait_ms": 5000,
          "semantic_hint": "scheduler 安排时间面板 visibility"
        },
        {
          "id": "open_date_picker",
          "action": "click",
          "target": {
            "selector": "ytcp-datetime-picker #datepicker-trigger",
            "fallbacks": [
              "ytcp-datetime-picker ytcp-text-dropdown-trigger",
              "ytcp-date-picker ytcp-dropdown-trigger",
              "ytcp-date-picker #trigger"
            ]
          },
          "wait_after_ms": 800,
          "retry": 3,
          "semantic_hint": "日期 date 日历 calendar 打开 dropdown"
        },
        {
          "id": "pick_date",
          "action": "pick_option",
          "container": "ytcp-date-picker",
          "item_selector": "span.calendar-day:not(.invisible):not(.disabled)",
          "match_text": "${day}",
          "wait_after_ms": 500,
          "retry": 5,
          "semantic_hint": "日期 day 选项 calendar"
        },
        {
          "id": "set_time",
          "action": "set_value",
          "target": {
            "selector": "#second-container input",
            "value_pattern": "^\\d{2}:\\d{2}$",
            "fallbacks": [
              "#time-of-day-container input",
              "input[type=\"text\"]"
            ]
          },
          "value": "${time}",
          "retry": 5,
          "wait_after_ms": 500,
          "semantic_hint": "时间 time 输入框 HH:MM"
        }
      ]
    },
    "popups": {
      "dismiss": [
        "#close-button",
        "#dismiss-button",
        ".ytcp-button[aria-label=\"Close\"]"
      ]
    }
  }
}
