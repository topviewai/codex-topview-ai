{
  "tiktok": {
    "wait_upload": {
      "error_signals": [
        {
          "selector": "text:无法处理",
          "desc": "视频无法处理"
        },
        {
          "selector": "text:Can't be processed",
          "desc": "Video cannot be processed"
        },
        {
          "selector": "text:Unable to process",
          "desc": "Unable to process video"
        },
        {
          "selector": "text:出错了",
          "desc": "上传出错"
        },
        {
          "selector": "text:Something went wrong",
          "desc": "Something went wrong"
        },
        {
          "selector": "text:Upload failed",
          "desc": "Upload failed"
        },
        {
          "selector": "text:上传失败",
          "desc": "上传失败"
        }
      ],
      "error_dismiss": [
        "@aria-label=Close",
        "text:替换",
        "text:Replace",
        "text:Cancel",
        "text:取消"
      ],
      "editor_ready": [
        "xpath://div[@contenteditable='true']"
      ]
    },
    "copyright": {
      "passed_signals": [
        "text:No issues found",
        "text:未发现问题"
      ],
      "toggle_selector": [
        "xpath://button[@role='switch' and @aria-checked='true']"
      ],
      "toggle_off_selector": [
        "xpath://button[@role='switch' and @aria-checked='false']"
      ]
    },
    "schedule": {
      "radio_selector": "input[name=\"postSchedule\"][value=\"schedule\"]",
      "date_input_class": "TUXTextInputCore-input",
      "date_value_pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "time_value_pattern": "^\\d{2}:\\d{2}$",
      "timepicker_item": ".tiktok-timepicker-option-item",
      "timepicker_hour": ".tiktok-timepicker-left",
      "timepicker_minute": ".tiktok-timepicker-right",
      "timepicker_active": "tiktok-timepicker-is-active",
      "schedule_button_text": [
        "Schedule",
        "定时发布",
        "预约发布"
      ],
      "now_radio_selector": "input[name=\"postSchedule\"][value=\"post_now\"]"
    },
    "schedule_recipe": {
      "version": 3,
      "steps": [
        {
          "id": "activate_schedule",
          "action": "click",
          "target": {
            "selector": "input[name=\"postSchedule\"][value=\"schedule\"]",
            "fallbacks": [
              "label.Radio__root:nth-child(2)"
            ]
          },
          "fallback": {
            "text_match": [
              "预约发布",
              "Schedule",
              "定时发布"
            ]
          },
          "wait_after_ms": 1500,
          "semantic_hint": "schedule 预约发布 定时发布 radio postSchedule"
        },
        {
          "id": "handle_consent_modal",
          "action": "click",
          "target": {
            "selector": ".TUXModal-overlay button[data-type=\"primary\"]",
            "fallbacks": [
              ".TUXModal-overlay .Button__root--type-primary",
              ".common-modal-confirm-modal button[data-type=\"primary\"]"
            ]
          },
          "fallback": {
            "text_match": [
              "允许",
              "Allow",
              "Agree"
            ]
          },
          "optional": true,
          "wait_before_ms": 500,
          "wait_after_ms": 1500,
          "retry": 2,
          "semantic_hint": "允许保存视频 consent modal 授权弹窗"
        },
        {
          "id": "open_date_picker",
          "action": "click",
          "target": {
            "selector": ".scheduled-picker > div:last-child .TUXInputBox",
            "fallbacks": [
              ".scheduled-picker > div:nth-child(2) .TUXInputBox",
              ".scheduled-picker > div:last-child input.TUXTextInputCore-input"
            ]
          },
          "wait_after_ms": 800,
          "retry": 3,
          "semantic_hint": "日期 date 日历 calendar 打开"
        },
        {
          "id": "pick_date",
          "action": "pick_option",
          "container": ".calendar-wrapper",
          "item_selector": "span.day.valid",
          "match_text": "${day}",
          "wait_after_ms": 500,
          "retry": 5,
          "semantic_hint": "日期 day 选项 calendar"
        },
        {
          "id": "open_time_picker",
          "action": "click",
          "target": {
            "selector": ".scheduled-picker > div:first-child .TUXInputBox",
            "fallbacks": [
              ".scheduled-picker > div:first-child input.TUXTextInputCore-input"
            ]
          },
          "wait_after_ms": 800,
          "retry": 3,
          "semantic_hint": "时间 time picker 打开"
        },
        {
          "id": "pick_hour",
          "action": "pick_option",
          "container": ".tiktok-timepicker-time-picker-container",
          "item_selector": "span.tiktok-timepicker-option-text.tiktok-timepicker-left",
          "match_text": "${hour}",
          "wait_after_ms": 300,
          "retry": 5,
          "semantic_hint": "小时 hour 选择列表 timepicker"
        },
        {
          "id": "pick_minute",
          "action": "pick_option",
          "container": ".tiktok-timepicker-time-picker-container",
          "item_selector": "span.tiktok-timepicker-option-text.tiktok-timepicker-right",
          "match_text": "${minute}",
          "wait_after_ms": 500,
          "retry": 5,
          "semantic_hint": "分钟 minute 选择列表 timepicker"
        }
      ]
    },
    "visibility_recipe": {
      "version": 3,
      "steps": [
        {
          "id": "open_dropdown",
          "action": "click",
          "target": {
            "selector": ".view-auth-container [role='combobox']",
            "fallbacks": [
              ".view-auth-container .Select__trigger",
              ".view-auth-container button[class*='Select']",
              "[role='combobox']"
            ]
          },
          "verify_text": [
            "Everyone",
            "Friends",
            "Only you",
            "Only me",
            "所有人",
            "好友",
            "仅自己"
          ],
          "fallback": {
            "text_match": [
              "Everyone",
              "Friends",
              "Only you",
              "Only me",
              "所有人",
              "好友",
              "仅自己"
            ]
          },
          "wait_after_ms": 800,
          "retry": 3,
          "semantic_hint": "可见性 visibility Who can watch 谁可以观看 combobox dropdown select"
        },
        {
          "id": "wait_options",
          "action": "wait",
          "target": {
            "selector": "[role='listbox']",
            "fallbacks": [
              ".Select__contentWrapper",
              "[role='menu']"
            ]
          },
          "max_wait_ms": 3000,
          "semantic_hint": "下拉菜单 dropdown listbox options visibility"
        },
        {
          "id": "select_option",
          "action": "pick_option",
          "container": "[role='listbox']",
          "item_selector": "[role='option']",
          "match_text": "${option_text}",
          "wait_after_ms": 500,
          "retry": 3,
          "semantic_hint": "${option_hint} 可见性 选项 option visibility"
        }
      ]
    },
    "publish_confirm": {
      "dialog_selectors": [
        "xpath://*[contains(@class,'TUXModal')]",
        "xpath://*[@role='dialog' or @role='alertdialog']",
        "xpath://*[contains(@class,'common-modal') or (contains(@class,'modal') and not(contains(@class,'modal-root')))]"
      ],
      "secondary_confirm": [
        "text:立即发布",
        "text:Publish now",
        "text:Post now",
        "text:Post anyway",
        "text:Post video",
        "text:Schedule anyway",
        "text:Schedule video",
        "text:仍然发布",
        "text:继续发布",
        "text:仍然上传",
        "text:Upload anyway",
        "text:Schedule",
        "text:定时发布",
        "text:Post"
      ]
    },
    "confirm": {
      "success_signals": [
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'已发布')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'发布成功')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'Your video has been published')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'Your video is now public')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'Video published')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'Scheduled for')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'已安排')]",
        "xpath://*[not(self::script) and not(self::style) and contains(text(),'成功')][@role='alert' or @role='dialog' or @role='status']"
      ],
      "success_url_pattern": {
        "not_contains": [
          "upload"
        ],
        "or_contains": [
          "manage",
          "content"
        ]
      }
    },
    "popups": {
      "dismiss": [
        "[aria-label=\"Close\"]",
        "[aria-label=\"关闭\"]",
        "text:Maybe later",
        "text:Not now",
        "text:Skip",
        "text:OK",
        "text:Got it",
        "text:Cancel",
        "text:取消",
        "text:以后再说",
        "text:跳过",
        "text:好的",
        "text:确定",
        "text:了解",
        "text:知道了",
        "text:Decline all",
        "text:Accept all",
        "text:允许",
        "text:Allow",
        ".TUXModal-overlay button[data-type=\"primary\"]",
        ".modal-close",
        ".close-icon",
        "#tux-portal-container .tux-button--text"
      ]
    }
  },
